{
  "name": "dll-structure-viewer",
  "displayName": "DLL Structure Viewer",
  "description": "View the structure of DLL and EXE files - exports, imports, dependency trees, PE headers, and sections",
  "version": "1.0.0",
  "publisher": "nhunter0",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dllViewer.viewStructure",
        "title": "View DLL Structure",
        "category": "DLL Viewer"
      }
    ],
    "customEditors": [
      {
        "viewType": "dllViewer.structureView",
        "displayName": "DLL Structure Viewer",
        "selector": [
          { "filenamePattern": "*.dll" },
          { "filenamePattern": "*.exe" },
          { "filenamePattern": "*.sys" },
          { "filenamePattern": "*.ocx" },
          { "filenamePattern": "*.drv" }
        ],
        "priority": "default"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname =~ /\\.(dll|exe|sys|ocx|drv)$/i",
          "command": "dllViewer.viewStructure",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "dllViewer.viewStructure",
          "when": "resourceExtname =~ /\\.(dll|exe|sys|ocx|drv)$/i"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
