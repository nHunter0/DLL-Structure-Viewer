{
  "name": "dll-structure-viewer",
  "displayName": "DLL Structure Viewer",
  "description": "View the structure of DLL, EXE, and SO files - exports, imports, dependency trees, PE/ELF headers, and sections",
  "version": "1.2.0",
  "publisher": "nhunter0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nHunter0/DLL-Structure-Viewer"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dllViewer.viewStructure",
        "title": "View DLL Structure",
        "category": "DLL Viewer"
      }
    ],
    "customEditors": [
      {
        "viewType": "dllViewer.structureView",
        "displayName": "DLL Structure Viewer",
        "selector": [
          {
            "filenamePattern": "*.dll"
          },
          {
            "filenamePattern": "*.exe"
          },
          {
            "filenamePattern": "*.sys"
          },
          {
            "filenamePattern": "*.ocx"
          },
          {
            "filenamePattern": "*.drv"
          },
          {
            "filenamePattern": "*.so"
          },
          {
            "filenamePattern": "*.so.*"
          },
          {
            "filenamePattern": "*.cpl"
          },
          {
            "filenamePattern": "*.scr"
          },
          {
            "filenamePattern": "*.efi"
          },
          {
            "filenamePattern": "*.mui"
          },
          {
            "filenamePattern": "*.ax"
          },
          {
            "filenamePattern": "*.ko"
          },
          {
            "filenamePattern": "*.elf"
          },
          {
            "filenamePattern": "*.axf"
          }
        ],
        "priority": "default"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname =~ /\\.(dll|exe|sys|ocx|drv|cpl|scr|efi|mui|ax|ko|elf|axf|so(\\.[0-9]+)*)$/i",
          "command": "dllViewer.viewStructure",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "dllViewer.viewStructure",
          "when": "resourceExtname =~ /\\.(dll|exe|sys|ocx|drv|cpl|scr|efi|mui|ax|ko|elf|axf|so(\\.[0-9]+)*)$/i"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
